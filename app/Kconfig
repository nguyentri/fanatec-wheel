# Application Kconfig entry point.

menu "Zephyr"
source "Kconfig.zephyr"
endmenu

module = APP
module-str = APP
source "subsys/logging/Kconfig.template.log_config"

config RIM_TM1637
	bool "Mirror display bytes to a TM1637 module"
	default n
	help
	  Optional display mirror (spec section 7). Requires the
	  TM1637 wired per the hardware spec; decode-to-shell works
	  without it.

config RIM_SHELL
	bool "Rim diagnostic shell"
	default y
	select SHELL
	help
	  Shell commands (rim mosi/miso/disp/btn/id/stats) reproducing the
	  reference sketch's serial command feature (spec section 4).

config RIM_FASTBOOT
	bool "Boot-deadline mode: link-first init, deferred services"
	default y
	help
	  (spec 2-S2): main() initializes only the fast path
	  (adapter seal -> SPI arm -> LINK_READY) and defers input/
	  output/diagnostic service init behind link readiness via the
	  system workqueue. Boot-to-ready is timestamped and reported
	  by the `rim boot` shell command for comparison against the
	  measured base first-poll deadline (>= 2x margin required).

config RIM_WATCHDOG
	bool "Watchdog fed from the input thread"
	select WATCHDOG
	help
	  Arms the hardware watchdog (100 ms) fed exclusively by the
	  input thread's 1 kHz tick (spec 4-S6). Default off on the
	  bench board to keep debugger sessions alive; production
	  builds enable it. Reset cause is captured via hwinfo.
