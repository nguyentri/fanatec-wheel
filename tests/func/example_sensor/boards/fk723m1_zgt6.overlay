 * SPDX-License-Identifier: Apache-2.0
 *
 * FK723M1-ZGT6 has no user button; the example sensor input is mapped
 * to PC13 (broken out on the header) - wire a button or jumper to GND
 * to exercise it. The blink LED reuses the on-board user LED (PG7,
 * active low).
 */

/ {
	example_sensor: example-sensor {
		compatible = "zephyr,example-sensor";
		input-gpios = <&gpioc 13 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
	};

	blink_led: blink-led {
		compatible = "blink-gpio-led";
		led-gpios = <&gpiog 7 GPIO_ACTIVE_LOW>; /* on-board user LED */
	};
};
