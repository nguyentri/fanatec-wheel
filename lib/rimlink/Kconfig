config RIMLINK_LEGACY_SPI
	bool "Rim-Link adapter v1 (legacy-spi)"
	help
	  Versioned adapter that isolates every observed protocol constant
	  of the legacy 33-byte SPI rim link (frame build/parse, CRC-8,
	  identity). Higher layers see logical inputs/outputs only; no
	  other module may reference frame offsets.
	  Reference: docs/phase1-software-spec.md, section 5.

if RIMLINK_LEGACY_SPI

config RIM_IDENTITY
	int "Default rim identity byte"
	range 1 4
	default 3
	help
	  Rim identity presented in frame byte 1:
	  1 = BMW GT2, 2 = ClubSport Formula,
	  3 = Porsche 918 RSR (reference default), 4 = UniHub.

module = RIMLINK
module-str = rimlink
source "subsys/logging/Kconfig.template.log_config"

endif # RIMLINK_LEGACY_SPI

config RIMLINK_CAPTURE
	bool "Transaction capture ring (link instrumentation)"
	depends on RIMLINK_LEGACY_SPI
	default y
	help
	  256-entry RAM ring of link transactions {timestamp, direction,
	  frame, crc_ok, cs_gap} for real-base evidence capture
	  (spec 2-S1). Armed/drained from diag_svc only; zero fast-path
	  cost when disarmed; freezes on anomaly for post-mortem (2-M2).
